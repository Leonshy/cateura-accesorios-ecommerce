APP_NAME="Cateura Accesorios"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-dominio.com.py

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PY

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cateura_ecommerce
DB_USERNAME=db_user
DB_PASSWORD=db_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=public

CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=mail.tu-dominio.com.py
MAIL_PORT=587
MAIL_USERNAME=hola@tu-dominio.com.py
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hola@cateuraaccesorios.com"
MAIL_FROM_NAME="${APP_NAME}"

# Integraciones (configurar desde el panel /admin/configuracion)
# HCAPTCHA_SITE_KEY=
# HCAPTCHA_SECRET_KEY=
# GOOGLE_ANALYTICS_ID=
# META_PIXEL_ID=
